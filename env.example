# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+79991234567

# OpenRouter-compatible LLM API (опционально)
# Можно оставить пустым и задать позже через /settoken
PRIMARY_LLM_URL=https://openrouter.ai/api/v1/chat/completions
PRIMARY_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
PRIMARY_LLM_API_KEY=your_openrouter_api_key_here

# Fallback LLM (используется, если primary модель вернула ошибку)
FALLBACK_LLM_URL=https://openrouter.ai/api/v1/chat/completions
FALLBACK_LLM_MODEL=openrouter/free
# Можно оставить пустым — тогда будет использован PRIMARY_LLM_API_KEY
FALLBACK_LLM_TOKEN=

# HTTP поведение LLM запросов
# Таймаут одного HTTP-запроса к модели (секунды)
LLM_REQUEST_TIMEOUT_SECONDS=20
# Количество попыток на одну модель (например, для 429)
LLM_MAX_RETRIES=5
# Пейсинг для бесплатных моделей (имя модели оканчивается на "free")
# Для платных моделей не применяется
PRIMARY_FREE_MODEL_INTERVAL_SECONDS=4
PRIMARY_FREE_MODEL_429_BACKOFF_SECONDS=12
PRIMARY_FREE_MODEL_429_BACKOFF_STEP_SECONDS=4
FALLBACK_FREE_MODEL_INTERVAL_SECONDS=4
FALLBACK_FREE_MODEL_429_BACKOFF_SECONDS=12
FALLBACK_FREE_MODEL_429_BACKOFF_STEP_SECONDS=4

# Логи
# Основной лог бота (с ротацией)
LOG_FILE_PATH=bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
# Отдельный лог LLM запросов/ответов (с ротацией)
LLM_TRAFFIC_LOG_PATH=llm_traffic.log
LLM_TRAFFIC_LOG_MAX_BYTES=20971520
LLM_TRAFFIC_LOG_BACKUP_COUNT=5

# Пути к локальным данным
# Для Docker обычно используют /data (через volume)
SESSION_NAME=telethon_session
SCHEDULES_FILE=schedules.db

# Admin access
ADMIN_USER_ID=your_telegram_user_id_here
