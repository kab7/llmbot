{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kab7/llmbot/blob/main/docs/schemas/schedule-record.schema.json",
  "title": "Persisted schedule record",
  "description": "The complete record produced by build_schedule_record and persisted in the schedules SQLite table.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "created_at",
    "last_run",
    "next_run",
    "chat_id",
    "target_type",
    "target_name",
    "period_type",
    "period_value",
    "query",
    "requested_model",
    "mark_as_read",
    "recurrence_type",
    "time",
    "interval_days",
    "weekday",
    "day_of_month"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "last_run": {
      "type": ["string", "null"]
    },
    "next_run": {
      "type": "string"
    },
    "chat_id": {
      "type": "integer"
    },
    "target_type": {
      "type": "string",
      "enum": ["chat", "folder"]
    },
    "target_name": {
      "type": "string",
      "minLength": 1
    },
    "period_type": {
      "type": ["string", "null"],
      "enum": ["days", "hours", "today", "last_messages", "unread", null]
    },
    "period_value": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "query": {
      "type": "string"
    },
    "requested_model": {
      "type": ["string", "null"]
    },
    "mark_as_read": {
      "type": "boolean"
    },
    "recurrence_type": {
      "type": "string",
      "enum": ["daily", "weekly", "monthly", "interval_days"]
    },
    "time": {
      "type": "string",
      "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"
    },
    "interval_days": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "weekday": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 6
    },
    "day_of_month": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 31
    }
  }
}
